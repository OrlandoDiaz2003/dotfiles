set number
set relativenumber
set termguicolors
set tabstop=4
set shiftwidth=4
set expandtab
set incsearch
set smartindent
set smartcase
set scrolloff=12
set signcolumn="yes"
set smoothscroll
set laststatus=2
set bg=dark

set noswapfile
set nocompatible
set nohlsearch
set nolist
set nowrap

syntax on
color retrobox 



