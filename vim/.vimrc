set number
set relativenumber
set tabstop=4
set shiftwidth=4
set expandtab
set incsearch
set smartindent
set smartcase
set scrolloff=12
set signcolumn="yes"
set guifont=Iosevka\ 16
set guioptions-=m
set guioptions-=T
set smoothscroll
set laststatus=2
set bg=dark
set termguicolors 

set noswapfile
set nocompatible
set nohlsearch
set nolist
set nowrap

syntax on 
color sorbet 
